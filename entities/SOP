{
  "name": "SOP",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "Rich text content of the SOP"
    },
    "category": {
      "type": "string",
      "enum": [
        "sales",
        "onboarding",
        "support",
        "operations",
        "general"
      ],
      "default": "general"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "archived"
      ],
      "default": "draft"
    },
    "deal_id": {
      "type": "string",
      "description": "Optional link to a deal for auto-generated SOPs"
    }
  },
  "required": [
    "title"
  ]
}
